# Optional: Stadia Maps API key — enables Stamen Terrain style (best for historical maps)
# Sign up free (no payment) at https://stadiamaps.com/
VITE_STADIA_API_KEY=

# Default map style URL. If VITE_STADIA_API_KEY is set, terrain is used automatically.
# Without a key, fiord (dark, subdued) is the built-in fallback.
VITE_DEFAULT_MAP_STYLE=https://tiles.openfreemap.org/styles/fiord
